    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "C:/MinGW/include",           // Pasta principal do MinGW
                "C:/MinGW/include/ncurses"    // Subpasta específica do ncurses
